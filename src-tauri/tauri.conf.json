{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "萤火集桌面端",
  "version": "3.0.2",
  "identifier": "com.yinghuoji.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "萤火集桌面端",
        "width": 1440,
        "height": 920,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "icon": ["icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE4NDI3RDFEREMyREQ4RjkKUldUNTJDM2NIWDFDcUU4b1NmaG1Wczh5MmkxVjBiNUcvdmV6V0I0L1NZUEd5dTNWdjgwS0lsY3kK",
      "endpoints": [
        "https://github.com/galaxywk223/yinghuoji-desktop/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
